{
  "name": "loftly-web",
  "version": "0.1.0",
  "private": true,
  "description": "Loftly web frontend \u2014 Next.js 15 App Router. Spec: ../loftly/mvp/UI_WEB.md",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:dev": "npx @cloudflare/next-on-pages && npx wrangler pages dev .vercel/output/static",
    "analyze": "ANALYZE=true next build",
    "size": "size-limit",
    "lighthouse": "lhci autorun --config=.lighthouserc.js"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "@sentry/nextjs": "^10.49.0",
    "clsx": "^2.1.1",
    "next": "15.1.3",
    "next-intl": "^3.26.3",
    "posthog-js": "^1.369.3",
    "posthog-node": "^5.21.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
    "@eslint/eslintrc": "^3.2.0",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@size-limit/preset-app": "^12.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.3",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "size-limit": "^12.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  }
}
