# loftly-web environment variables
# Source of truth: ../loftly/mvp/DEPLOYMENT.md §Environment variables § loftly-web
# Copy to `.env.local` for local dev. Never commit secrets.

# Public — safe to expose to the browser
NEXT_PUBLIC_API_BASE=https://api.loftly.co.th/v1
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=

# OAuth client IDs (public — public-by-design for OAuth flows)
LOFTLY_OAUTH_LINE_CLIENT_ID=
LOFTLY_OAUTH_GOOGLE_CLIENT_ID=
LOFTLY_OAUTH_APPLE_CLIENT_ID=

# Secrets — set via Cloudflare Pages Secrets in prod, `.env.local` for dev
# Rotate quarterly per DEPLOYMENT.md §Secret scanning
INTERNAL_API_KEY=
SESSION_ENCRYPTION_KEY=
